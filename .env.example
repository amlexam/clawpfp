# ╔══════════════════════════════════════════════════════════════════╗
# ║                     ClawPFP Configuration                       ║
# ║  Open-source cNFT minting infrastructure for AI agents          ║
# ║  https://github.com/aarjn/clawpfp                               ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED].
# Everything else has sensible defaults.


# ──────────────────────────────────────────────────────────────────
# SOLANA CONFIGURATION
# ──────────────────────────────────────────────────────────────────

# [REQUIRED] Solana RPC endpoint
# Devnet (free):  https://api.devnet.solana.com
# Mainnet:        Use a paid RPC for reliability (Helius, Triton, QuickNode)
# Helius example: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_RPC_URL=https://api.devnet.solana.com

# [REQUIRED] Server keypair — this wallet pays for all mints and tree creation
#
# Two formats supported:
#   JSON array:  [174,47,154,16,202,...]   (same as solana-keygen output)
#   Base64:      rC+aEMoA...==             (recommended for Railway/Docker)
#
# Generate one:  solana-keygen new --outfile keypair.json
# Convert to base64:
#   python3 -c "import json,base64; print(base64.b64encode(bytes(json.load(open('keypair.json')))).decode())"
#
# Fund it with devnet SOL:  solana airdrop 2 --keypair keypair.json
PAYER_KEYPAIR=[174,47,154,16,202,...]


# ──────────────────────────────────────────────────────────────────
# COLLECTION CONFIGURATION
# ──────────────────────────────────────────────────────────────────

# [SET AFTER SETUP] Collection NFT address
# Run `cargo run -- setup` to create your collection, then paste the address here.
# Leave empty on first run.
COLLECTION_MINT=

# Collection name — each minted NFT is named "{name} #{index}"
# Example: "Dreamer" produces "Dreamer #0", "Dreamer #1", "Dreamer #2"
COLLECTION_NAME=Dreamer

# Token symbol (1-10 characters, uppercase)
COLLECTION_SYMBOL=DRM

# Royalty fee in basis points (100 = 1%, 500 = 5%, 1000 = 10%)
# This is the secondary sale royalty enforced by marketplaces
SELLER_FEE_BASIS_POINTS=500

# Description embedded in every NFT's on-chain metadata
# Must be quoted if it contains special characters
COLLECTION_DESCRIPTION="A compressed NFT minted by an AI agent via challenge-response."

# Image URL for each minted NFT
# Supports {mint_index} placeholder — replaced with the mint number for unique images
#
# DiceBear generates unique pixel-art avatars per mint. Customize:
#   - backgroundColor: hex colors (comma-separated for random pick)
#   - backgroundType: solid or gradientLinear
#   - glassesProbability: 0-100 chance of glasses
#   - hatProbability: 0-100 chance of hat
#   - accessoriesProbability: 0-100 chance of accessories
#   - beardProbability: 0-100 chance of beard
#   - size: image dimensions in pixels
#   - radius: corner rounding (0-50)
#
# Explore styles: https://www.dicebear.com/styles/pixel-art/
# Or use any static image URL (remove {mint_index} for same image on all NFTs)
COLLECTION_IMAGE_URL=https://api.dicebear.com/9.x/pixel-art/svg?seed=cnft-{mint_index}&backgroundColor=6c5ce7,00b894,fd79a8,fdcb6e,74b9ff&backgroundType=gradientLinear&backgroundRotation=0,360&radius=10&size=512&glassesProbability=40&hatProbability=30&accessoriesProbability=50&beardProbability=20


# ──────────────────────────────────────────────────────────────────
# MERKLE TREE CONFIGURATION
# ──────────────────────────────────────────────────────────────────

# These control the on-chain Merkle tree that stores compressed NFTs.
# A tree is auto-created on the first mint and costs ~0.68 SOL.
# When full, a new tree is created automatically.
#
# Capacity = 2^MAX_DEPTH (14 = 16,384 NFTs per tree)
#
# Depth / Buffer / Canopy combinations (from Metaplex docs):
#   Depth 14, Buffer 64,  Canopy 10 → 16,384 NFTs, ~0.68 SOL  (recommended)
#   Depth 20, Buffer 256, Canopy 15 → 1M NFTs,     ~1.5 SOL
#   Depth 30, Buffer 512, Canopy 20 → 1B NFTs,     ~3.5 SOL
MERKLE_TREE_MAX_DEPTH=14
MERKLE_TREE_MAX_BUFFER_SIZE=64
MERKLE_TREE_CANOPY_DEPTH=10


# ──────────────────────────────────────────────────────────────────
# METADATA STORAGE (Irys / Arweave)
# ──────────────────────────────────────────────────────────────────

# NFT metadata JSON is uploaded to Arweave (permanent storage) via Irys.
# Each upload costs ~10,612 lamports (~$0.000002).
#
# You must fund your Irys account before minting:
#   solana transfer 4a7s9iC5NwfUtf8fXpKWxYXcekfqiN6mRqipYXMtcrUS 0.01 \
#     --url https://api.devnet.solana.com --keypair <your-keypair>
#
# 0.01 SOL ≈ 900 mints on devnet.
#
# Check balance:
#   curl "https://devnet.irys.xyz/account/balance/solana?address=YOUR_PUBKEY"
#
# Devnet:  https://devnet.irys.xyz
# Mainnet: https://node1.irys.xyz or https://node2.irys.xyz
IRYS_NODE_URL=https://devnet.irys.xyz


# ──────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL / Supabase)
# ──────────────────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL connection string
#
# Recommended: Supabase (free tier works fine)
#   1. Create project at https://supabase.com
#   2. Go to Project Settings → Database → Connection string → URI
#   3. Use the "Transaction" pooler (port 6543) for serverless deployments
#   4. Use the "Session" pooler (port 5432) if you need prepared statements
#
# Format: postgresql://user:password@host:port/database
#
# Special characters in password must be URL-encoded:
#   ! → %21,  + → %2B,  * → %2A,  ) → %29,  @ → %40
DATABASE_URL=postgresql://postgres.xxxx:your-password@aws-0-region.pooler.supabase.com:6543/postgres


# ──────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ──────────────────────────────────────────────────────────────────

# Bind address (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
HOST=0.0.0.0

# HTTP port (Railway auto-injects PORT — don't set it in Railway)
PORT=3000

# Rate limiting — requests per second per IP
RATE_LIMIT_PER_SECOND=2

# Rate limiting — burst capacity (allows short bursts above the rate limit)
RATE_LIMIT_BURST=10

# How long challenges remain valid (in seconds)
# Default: 300 = 5 minutes
CHALLENGE_EXPIRY_SECONDS=300


# ──────────────────────────────────────────────────────────────────
# LOGGING
# ──────────────────────────────────────────────────────────────────

# Log levels: error, warn, info, debug, trace
# Format: module=level,module=level
# Set to "debug" for verbose output during development
RUST_LOG=clawpfp=info,tower_http=debug
